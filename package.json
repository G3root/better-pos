{
  "name": "better-pos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @better-pos/db db:push",
    "db:studio": "turbo -F @better-pos/db db:studio",
    "db:generate": "turbo -F @better-pos/db db:generate",
    "db:migrate": "turbo -F @better-pos/db db:migrate",
    "db:start": "turbo -F @better-pos/db db:start",
    "db:watch": "turbo -F @better-pos/db db:watch",
    "db:stop": "turbo -F @better-pos/db db:stop",
    "db:down": "turbo -F @better-pos/db db:down",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@better-pos/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-pos/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.8.1"
  },
  "packageManager": "pnpm@11.5.0"
}
